{
  "name": "wolfhq-fivem-command-center",
  "version": "2.1.6",
  "description": "WOLFHQ local-first command center for FiveM server projects.",
  "productName": "WOLFHQ",
  "author": "Neko Wolf Dev",
  "license": "MIT",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "package:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "release:win": "npm run package:win",
    "start": "electron .",
    "check": "vite build",
    "test": "node --test tests/*.test.cjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@uiw/react-codemirror": "^4.25.6",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.22.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.wolfstudios.wolfhq",
    "productName": "WOLFHQ",
    "executableName": "WOLFHQ",
    "artifactName": "WOLFHQ-Setup-${version}-${arch}.${ext}",
    "copyright": "Copyright © 2026 Wolf Studios Inc. Developed by Neko Wolf Dev.",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "build/icon.ico",
      "build/icon.png",
      "public/assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "legalTrademarks": "WOLFHQ is developed by Neko Wolf Dev.",
      "signAndEditExecutable": true,
      "signExecutable": false,
      "forceCodeSigning": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "WOLFHQ",
      "displayLanguageSelector": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "LairOfWolf",
      "repo": "WOLFHQ",
      "private": false
    }
  }
}
