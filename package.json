{
  "name": "wolfhq-fivem-command-center",
  "version": "2.1.0",
  "description": "WOLFHQ local-first command center for FiveM server projects.",
  "productName": "WOLFHQ",
  "author": "Wolf Studios Inc.",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "check": "vite build",
    "test": "node --test tests/*.test.cjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@uiw/react-codemirror": "^4.25.6",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.22.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "vite": "^6.0.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.wolfstudios.wolfhq",
    "productName": "WOLFHQ",
    "win": {
      "icon": "build/icon.ico"
    }
  }
}
